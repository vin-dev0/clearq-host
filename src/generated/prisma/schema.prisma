generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  emailVerified        DateTime?
  name                 String?
  image                String?
  passwordHash         String?
  avatar               String?
  role                 String          @default("CLIENT")
  plan                 String          @default("STARTER")
  department           String?
  phone                String?
  timezone             String          @default("UTC")
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  lastLoginAt          DateTime?
  organizationId       String?
  subscriptionStatus   String          @default("TRIALING")
  trialEndsAt          DateTime?
  subscriptionEndsAt   DateTime?
  gracePeriodEndsAt    DateTime?
  lastPaymentAt        DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  twoFactorCode        String?
  twoFactorCodeExpires DateTime?
  accounts             Account[]
  activityLogs         ActivityLog[]
  createdAssets        Asset[]         @relation("AssetCreator")
  calendarEvents       CalendarEvent[]
  comments             Comment[]
  notifications        Notification[]
  sessions             Session[]
  teamMemberships      TeamMember[]
  createdTickets       Ticket[]        @relation("TicketCreator")
  assignedTickets      Ticket[]        @relation("TicketAssignee")
  watchedTickets       TicketWatcher[]
  articles             Article[]
  organization         Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([role])
  @@index([subscriptionStatus])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id                   String            @id @default(cuid())
  name                 String
  slug                 String            @unique
  logo                 String?
  domain               String?
  settings             String            @default("{}")
  isDemo               Boolean           @default(false)
  expiresAt            DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  plan                 String            @default("STARTER")
  subscriptionStatus   String            @default("TRIALING")
  trialEndsAt          DateTime?
  subscriptionEndsAt   DateTime?
  clientFeePaid        Boolean           @default(false)
  gracePeriodEndsAt    DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripeApiKey         String?
  assets               Asset[]
  calendarEvents       CalendarEvent[]
  chatRooms            ChatRoom[]
  inventory            Inventory[]
  inviteCodes          InviteCode[]
  savedViews           SavedView[]
  tags                 Tag[]
  teams                Team[]
  templates            Template[]
  tickets              Ticket[]
  users                User[]
  articles             Article[]
  articleCategories    ArticleCategory[]
  csats                CSAT[]

  @@index([slug])
}

model Team {
  id             String       @id @default(cuid())
  name           String
  description    String?
  color          String       @default("#6366f1")
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  chatRooms      ChatRoom[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        TeamMember[]
  tickets        Ticket[]

  @@index([organizationId])
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Ticket {
  id              String          @id @default(cuid())
  number          Int
  subject         String
  description     String
  status          String          @default("OPEN")
  priority        String          @default("MEDIUM")
  type            String          @default("QUESTION")
  channel         String          @default("WEB")
  creatorId       String
  assigneeId      String?
  teamId          String?
  organizationId  String?
  dueAt           DateTime?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  isLocked        Boolean         @default(false)
  customFields    String          @default("{}")
  metadata        String          @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  activities      ActivityLog[]
  attachments     Attachment[]
  csat            CSAT?
  comments        Comment[]
  creator         User            @relation("TicketCreator", fields: [creatorId], references: [id])
  assignee        User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  team            Team?           @relation(fields: [teamId], references: [id])
  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tags            TicketTag[]
  watchers        TicketWatcher[]

  @@unique([number, organizationId])
  @@index([status])
  @@index([priority])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([teamId])
  @@index([createdAt])
  @@index([number])
}

model Template {
  id             String        @id @default(cuid())
  name           String
  type           String        @default("ticket")
  subject        String?
  content        String
  category       String        @default("General")
  isFavorite     Boolean       @default(false)
  usageCount     Int           @default(0)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
}

model CSAT {
  id             String        @id @default(cuid())
  rating         Int
  comment        String?
  ticketId       String        @unique
  userId         String?
  createdAt      DateTime      @default(now())
  organizationId String?
  ticket         Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([organizationId])
}

model Comment {
  id          String       @id @default(cuid())
  content     String
  isInternal  Boolean      @default(false)
  ticketId    String
  authorId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  author      User         @relation(fields: [authorId], references: [id])
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  ticketId  String?
  commentId String?
  createdAt DateTime @default(now())
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model TicketWatcher {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
}

model Tag {
  id             String        @id @default(cuid())
  name           String
  color          String        @default("#6366f1")
  description    String?
  organizationId String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets        TicketTag[]

  @@unique([name, organizationId])
}

model TicketTag {
  id       String @id @default(cuid())
  ticketId String
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, tagId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  ticketId   String?
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())
  ticket     Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([ticketId])
  @@index([createdAt])
}

model SavedView {
  id             String        @id @default(cuid())
  name           String
  filters        String
  columns        String        @default("[]")
  sortBy         String?
  sortOrder      String        @default("desc")
  isDefault      Boolean       @default(false)
  isShared       Boolean       @default(false)
  userId         String
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

model Article {
  id             String           @id @default(cuid())
  title          String
  slug           String
  content        String
  excerpt        String?
  keywords       String?
  status         String           @default("DRAFT")
  isPublished    Boolean          @default(false)
  categoryId     String?
  authorId       String
  organizationId String
  audience       String           @default("PUBLIC")
  viewCount      Int              @default(0)
  helpfulCount   Int              @default(0)
  publishedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  category       ArticleCategory? @relation(fields: [categoryId], references: [id])
  author         User             @relation(fields: [authorId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([slug, organizationId])
  @@index([status])
  @@index([categoryId])
  @@index([organizationId])
}

model ArticleCategory {
  id             String            @id @default(cuid())
  name           String
  slug           String
  description    String?
  icon           String?
  parentId       String?
  organizationId String
  order          Int               @default(0)
  createdAt      DateTime          @default(now())
  articles       Article[]
  parent         ArticleCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       ArticleCategory[] @relation("CategoryHierarchy")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([slug, organizationId])
  @@index([parentId])
  @@index([organizationId])
}

model ChatRoom {
  id             String           @id @default(cuid())
  name           String
  description    String?
  type           String           @default("PUBLIC")
  teamId         String?
  organizationId String?
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  messages       ChatMessage[]
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team?            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members        ChatRoomMember[]

  @@index([teamId])
  @@index([organizationId])
}

model ChatRoomMember {
  id         String   @id @default(cuid())
  chatRoomId String
  userId     String
  role       String   @default("member")
  joinedAt   DateTime @default(now())
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
}

model ChatMessage {
  id             String        @id @default(cuid())
  content        String
  chatRoomId     String?
  senderId       String
  receiverId     String?
  replyToId      String?
  isEdited       Boolean       @default(false)
  isRead         Boolean       @default(false)
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  attachmentSize Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  replyTo        ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        ChatMessage[] @relation("MessageReplies")
  chatRoom       ChatRoom?     @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Asset {
  id             String        @id @default(cuid())
  assetTag       String
  name           String
  type           String        @default("LAPTOP")
  manufacturer   String?
  model          String?
  serialNumber   String?       @unique
  status         String        @default("AVAILABLE")
  organizationId String?
  location       String?
  department     String?
  assignedToId   String?
  assignedToName String?
  purchaseDate   DateTime?
  purchasePrice  Float?
  warrantyExpiry DateTime?
  vendor         String?
  poNumber       String?
  specifications String        @default("{}")
  notes          String?
  barcodeData    String?
  barcodeFormat  String        @default("CODE128")
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lastAuditDate  DateTime?
  createdBy      User          @relation("AssetCreator", fields: [createdById], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([assetTag, organizationId])
  @@index([assetTag])
  @@index([type])
  @@index([status])
  @@index([assignedToId])
  @@index([serialNumber])
  @@index([organizationId])
}

model InviteCode {
  id             String        @id @default(cuid())
  code           String        @unique
  email          String?
  plan           String        @default("STARTER")
  organizationId String?
  usedBy         String?
  usedAt         DateTime?
  expiresAt      DateTime?
  maxUses        Int           @default(1)
  currentUses    Int           @default(0)
  createdById    String
  createdAt      DateTime      @default(now())
  notes          String?
  type           String        @default("DIRECT")
  targetRole     String        @default("CLIENT")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([email])
  @@index([usedBy])
  @@index([organizationId])
}

model JoinRequest {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  inviteCodeId   String?
  status         String    @default("PENDING")
  message        String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId, status])
}

model AccessLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  userAgent  String?
  browser    String?
  os         String?
  device     String?
  path       String
  method     String
  statusCode Int?
  action     String
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model Inventory {
  id             String       @id @default(cuid())
  sku            String
  name           String
  category       String
  quantity       Int          @default(0)
  minStock       Int          @default(0)
  price          Float        @default(0)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([sku, organizationId])
  @@index([organizationId])
  @@index([category])
}

model CalendarEvent {
  id             String       @id @default(cuid())
  title          String
  type           String       @default("meeting")
  date           DateTime
  time           String
  organizationId String
  createdById    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([date])
}

model RemoteSession {
  id             String   @id @default(cuid())
  name           String
  type           String
  host           String
  port           Int
  username       String
  passwordHash   String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}
